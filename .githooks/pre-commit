#!/usr/bin/env bash
# review-gate:managed-hook — review-gate OWNS this file; the installer may overwrite
# it on reinstall. (A hook of YOURS that merely CALLS review-gate won't carry this
# marker, so the installer leaves it alone.)
# review-gate pre-commit hook (universal enforcement — fires for any actor that
# runs `git commit`: terminal, human, Claude Code, Codex, Cursor, Windsurf, ...).
# Defers to the repo-local gate; no-ops if the gate is absent or the repo is not
# in commit mode. Bypass (honesty escape hatch): git commit --no-verify
ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
GATE="$ROOT/.review-gate/review-gate.sh"
[ -n "$ROOT" ] && [ -f "$GATE" ] || exit 0
exec bash "$GATE" precommit
